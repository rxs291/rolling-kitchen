{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rolling-kitchen",
  "main": "src/index.js",
  "compatibility_date": "2026-05-28",
  "observability": {
    "enabled": true,
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
  },
  "compatibility_flags": ["nodejs_compat"],
}
